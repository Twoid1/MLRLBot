            features[f'return_{period}'] = df['close'].pct_change(period)
            features[f'high_low_ratio_{period}'] = df['high'].rolling(period).max() / df['low'].rolling(period).min()
        
        # Technical indicators
        features['rsi_14'] = self.calculate_rsi(df['close'], 14)
        features['macd'], features['macd_signal'] = self.calculate_macd(df['close'])
        features['bb_upper'], features['bb_lower'] = self.calculate_bollinger_bands(df['close'])
        features['atr'] = self.calculate_atr(df)
        features['adx'] = self.calculate_adx(df)
        
        # Volume features
        features['volume_ratio'] = df['volume'] / df['volume'].rolling(20).mean()
        features['obv'] = self.calculate_obv(df)
        
        # Multi-timeframe features (if multiple timeframes provided)
        # Added in the multi-timeframe wrapper
        
        return features
        
    def calculate_rsi(self, prices, period=14):
        delta = prices.diff()
        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()
        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()
        rs = gain / loss
        rsi = 100 - (100 / (1 + rs))
        return rsi
