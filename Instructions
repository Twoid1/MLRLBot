```python
def train_system():
    # 1. Fetch data
    data_fetcher = KrakenDataFetcher()
    data = {}
    for pair in ['XBTUSD', 'ETHUSD', 'SOLUSD']:
        data[pair] = data_fetcher.fetch_ohlc(pair, interval=60, days_back=365)
    
    # 2. Calculate features
    feature_engineer = FeatureEngineer()
    features = {}
    for pair, df in data.items():
        features[pair] = feature_engineer.calculate_features(df)
    
    # 3. Train ML model
    ml_predictor = MLPredictor()
    ml_predictor.train(features)
    
    # 4. Create environment
    env = TradingEnvironment(data['XBTUSD'])
    
    # 5. Train RL agent
    agent = DQNAgent(state_dim=63, action_dim=3)
    
    for episode in range(1000):
        state = env.reset()
        total_reward = 0
        
        while not env.done:
            action = agent.act(state)
            next_state, reward, done, _ = env.step(action)
            agent.remember(state, action, reward, next_state, done)
            state = next_state
            total_reward += reward
            
            if len(agent.memory) > 32:
                agent.replay()
        
        print(f"Episode {episode}, Total Reward: {total_reward}")
        
        # Update target network
        if episode % 10 == 0:
            agent.target_network.load_state_dict(agent.q_network.state_dict())
    
    return agent, ml_predictor
```

